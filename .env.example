# ============================================================
# SmallClaimsHelper — Environment Variables
# ============================================================
# Copy this file to .env.local for local development
# Add these same variables in Vercel dashboard → Settings → Environment Variables

# Supabase — get from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Site URL (update when deployed)
NEXT_PUBLIC_SITE_URL=https://smallclaimshelper.com
